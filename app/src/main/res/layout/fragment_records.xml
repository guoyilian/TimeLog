<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".RecordsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="@dimen/spacing_m"
        android:layout_marginEnd="@dimen/spacing_m"
        android:layout_marginTop="@dimen/spacing_s"
        android:layout_marginBottom="@dimen/spacing_s"
        android:background="@drawable/tab_bg">

        <Button
            android:id="@+id/sub_tab_day"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="日"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:background="@drawable/subtab_active_bg"
            android:textColor="@color/white"/>

        <Button
            android:id="@+id/sub_tab_week"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="周"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:background="@drawable/subtab_inactive_bg"
            android:textColor="@color/accent"/>

        <Button
            android:id="@+id/sub_tab_month"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="月"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:background="@drawable/subtab_inactive_bg"
            android:textColor="@color/accent"/>

        <Button
            android:id="@+id/sub_tab_year"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="年"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:background="@drawable/subtab_inactive_bg"
            android:textColor="@color/accent"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/view_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_m">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:layout_marginBottom="@dimen/spacing_l"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <com.example.timer.DayLineChartView
                            android:id="@+id/day_line_chart"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/day_chart_height"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/list_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日记录"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5A7D5A"
                    android:layout_marginTop="@dimen/spacing_s"
                    android:layout_marginBottom="@dimen/spacing_s"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/day_timeline_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="300dp"
                    android:overScrollMode="never"
                    android:clipToPadding="false"
                    android:paddingTop="8dp"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/view_chart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_m"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:id="@+id/week_chart_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:layout_marginBottom="@dimen/spacing_l"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <com.example.timer.WeekBarChartView
                            android:id="@+id/week_bar_chart"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/week_chart_height"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/month_heatmap_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:layout_marginBottom="@dimen/spacing_l"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <com.example.timer.MonthHeatmapView
                            android:id="@+id/month_heatmap"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/heatmap_chart_height"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/year_heatmap_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone">

                    <com.example.timer.YearStatisticsView
                        android:id="@+id/year_statistics_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/chart_task_stats_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_l"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="4dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/chart_stats_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="本周统计"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#5A7D5A"
                            android:layout_marginBottom="12dp"/>

                        <com.example.timer.SolidPieChartView
                            android:id="@+id/chart_stats_pie_chart"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:layout_marginBottom="12dp"/>

                        <com.example.timer.FlowLayout
                            android:id="@+id/chart_stats_tags_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/chart_list_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本周记录"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#5A7D5A"
                    android:layout_marginTop="@dimen/spacing_l"
                    android:layout_marginBottom="@dimen/spacing_m"/>

                <LinearLayout
                    android:id="@+id/week_timeline_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:backgroundTint="#3A9D5E"
        android:tint="@color/white"
        app:tint="@color/white"
        app:elevation="6dp"
        app:fabSize="normal"/>

</FrameLayout>