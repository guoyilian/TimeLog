<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_bg"
    android:orientation="vertical"
    android:paddingTop="32dp"
    android:paddingLeft="20dp"
    android:paddingRight="20dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="修改计时时间"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#3A4D3F"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <!-- 时间选择区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- 开始时间 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始时间"
                android:textSize="14sp"
                android:textColor="#5C6B61"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- 小时选择器 -->
                <NumberPicker
                    android:id="@+id/np_start_hour"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:descendantFocusability="blocksDescendants"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textSize="20sp"
                    android:textColor="#3A4D3F"
                    android:textStyle="bold"
                    android:layout_gravity="center_vertical"/>

                <!-- 分钟选择器 -->
                <NumberPicker
                    android:id="@+id/np_start_minute"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:descendantFocusability="blocksDescendants"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#E8E8E8"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"/>

        <!-- 结束时间 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="结束时间"
                android:textSize="14sp"
                android:textColor="#5C6B61"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- 小时选择器 -->
                <NumberPicker
                    android:id="@+id/np_end_hour"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:descendantFocusability="blocksDescendants"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=":"
                    android:textSize="20sp"
                    android:textColor="#3A4D3F"
                    android:textStyle="bold"
                    android:layout_gravity="center_vertical"/>

                <!-- 分钟选择器 -->
                <NumberPicker
                    android:id="@+id/np_end_minute"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:descendantFocusability="blocksDescendants"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/ripple_gray"
            app:backgroundTint="@null"
            android:text="取消"
            android:textSize="16sp"
            android:textColor="#5C6B61"
            android:layout_marginRight="8dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/ripple_green"
            app:backgroundTint="@null"
            android:text="确定"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="8dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>